# --- Backend (Flask) ---
API_HOST=0.0.0.0
API_PORT=5001
FLASK_DEBUG=true

# Göreli yollar backend/ köküne göre çözülür (cwd'den bağımsız)
UPLOAD_DIR=data/uploads
REGISTRY_PATH=data/documents.json
CHUNKS_DIR=data/chunks
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Docling: auto | gpu | cpu | cuda | mps
DOCLING_DEVICE=cpu
DOCLING_DO_OCR=true
DOCLING_ALLOW_MPS=false
DOCLING_NUM_THREADS=4
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_RATIO=0.15

ENABLE_LLM_CHUNK_ENRICHMENT=false
LLM_ENRICH_MAX_CHARS=24000
CHROMA_PATH=data/chroma
CHROMA_COLLECTION=rag_chunks
EMBEDDING_BATCH_SIZE=32

# Ücretsiz katman ~100 embed isteği/dk; 0.7 ≈ dakikada 85 istek
EMBEDDING_MIN_INTERVAL_SEC=0.7
EMBEDDING_MAX_RETRIES=8

# --- Frontend (Vite; API_PORT ile aynı port) ---
VITE_USE_MOCK=false
VITE_API_URL=http://localhost:5001

# --- UC4 arama (B4) ---
QUERY_MIN_LENGTH=10
QUERY_MAX_LENGTH=500
SIMILARITY_THRESHOLD=0.50
RAG_TOP_K=5
RAG_TEMPERATURE=0.2
RAG_MAX_HISTORY_TURNS=10

# --- Gemini ---
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_LLM_MODEL=gemini-2.5-flash
